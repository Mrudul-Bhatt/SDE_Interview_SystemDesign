      "text": "Background  (compacted topics only)\nLogCompactor: Pass 1 latest[key] wins · Pass 2 strip null-value tombstones · result = one message per key, deleted keys absent",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "bg-procs",
      "originalText": "Background  (compacted topics only)\nLogCompactor: Pass 1 latest[key] wins · Pass 2 strip null-value tombstones · result = one message per key, deleted keys absent",
      "lineHeight": 1.25,
      "index": "aE",
