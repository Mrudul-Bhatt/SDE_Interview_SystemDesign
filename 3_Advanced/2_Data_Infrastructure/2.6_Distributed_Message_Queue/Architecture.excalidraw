    {
      "id": "legend-text",
      "type": "text",
      "x": 20,
      "y": 695,
      "width": 960,
      "height": 190,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
